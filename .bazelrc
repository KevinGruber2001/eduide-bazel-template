# bzlmod is the default in Bazel 7; keep it explicit for clarity.
common --enable_bzlmod

# Show test failures inline.
test --test_output=errors

# The benchmark harness adds the remote cache at the command line, e.g.:
#   bazel build //... --remote_cache=http://eduide-shared-cache.<ns>.svc.cluster.local:8080/bazel/
# (no credentials needed while cache auth is disabled)
